---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import RelatedPages from "../components/related-pages.astro";

// Generate paths for each blog post
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug.replace(/^blog\//, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
// Render markdown content AFTER post exists
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.snippet}>
  <article class="prose dark:prose-invert mx-auto">
    <Content />
  </article>
  {post.data.showRelated && <RelatedPages current={`/${post.slug}`} />}
</Layout>
