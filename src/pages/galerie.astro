---
import Base from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const images = [
  { src: "/assets/FUKU-Bonheur.webp", alt: "Calligraphie du caractère 福 (Bonheur)" },
  { src: "/assets/Shin-1-c2g.webp", alt: "Calligraphie à l'encre de Chine sur papier" },
  { src: "/assets/art-energetique-chinois.webp", alt: "Art énergétique chinois au pinceau" },
  { src: "/assets/atelier-de-groupe-calligraphie-lyon.webp", alt: "Participants à un atelier de calligraphie en groupe" },
  { src: "/assets/calligraphie-japonaise.webp", alt: "Calligraphie japonaise à l'encre" },
  { src: "/assets/cours-calligraphie-comites-entreprise.webp", alt: "Atelier de calligraphie pour un comité d'entreprise" },
  { src: "/assets/cours-calligraphie-lycees.webp", alt: "Élèves de lycée pratiquant la calligraphie" },
  { src: "/assets/cours-calligraphie-universites-grandes-ecoles.webp", alt: "Étudiants pratiquant la calligraphie" },
  { src: "/assets/cours-de-chinois.webp", alt: "Cours de chinois et initiation aux sinogrammes" },
];
---

<Base title="Calligraphies" description="Galerie de calligraphies chinoises de Christophe Desmur à Lyon. Œuvres à l'encre de Chine disponibles à la vente ou réalisées sur commande personnalisée.">
  <main class="mx-auto max-w-[735px] mt-14">

<h2 class="text-4xl lg:text-5xl font-bold text-gray-800">Galerie</h2>
    <p class="text-lg mt-4 text-gray-600">Pour acquérir l'une des calligraphies ci-dessous ou me demander une calligraphie personnalisée, merci de m'écrire à <a href="mailto:christophe.desmur@orange.fr">christophe.desmur@orange.fr</a>.
</p>


    <!-- Galerie -->
    <div class="mt-12">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {images.map((image, index) => (
          <img
            src={image.src}
            alt={image.alt}
            class="rounded-lg shadow-md w-full object-cover cursor-pointer hover:opacity-80 transition"
            data-index={index}
            data-alt={image.alt}
          />
        ))}
      </div>
    </div>
  </main>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-black bg-opacity-80 hidden items-center justify-center z-50">
    <button id="prev" class="absolute left-4 text-white text-3xl top-1/2 -translate-y-1/2">&#10094;</button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90%] max-w-[90%] rounded-lg shadow-xl" />
    <button id="next" class="absolute right-4 text-white text-3xl top-1/2 -translate-y-1/2">&#10095;</button>
  </div>

  <script is:inline client:load>
    const images = document.querySelectorAll("[data-index]");
    const lightbox = document.getElementById("lightbox");
    const img = document.getElementById("lightbox-img");
    const prevBtn = document.getElementById("prev");
    const nextBtn = document.getElementById("next");

    let currentIndex = 0;

    function showLightbox(index) {
      currentIndex = index;
      img.src = images[currentIndex].getAttribute("src");
      img.alt = images[currentIndex].getAttribute("data-alt") || "";
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
    }

    function hideLightbox() {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
    }

    function showPrev() {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      img.src = images[currentIndex].getAttribute("src");
      img.alt = images[currentIndex].getAttribute("data-alt") || "";
    }

    function showNext() {
      currentIndex = (currentIndex + 1) % images.length;
      img.src = images[currentIndex].getAttribute("src");
      img.alt = images[currentIndex].getAttribute("data-alt") || "";
    }

    images.forEach((image, index) => {
      image.addEventListener("click", () => showLightbox(index));
    });

    prevBtn.addEventListener("click", (e) => { e.stopPropagation(); showPrev(); });
    nextBtn.addEventListener("click", (e) => { e.stopPropagation(); showNext(); });
    lightbox.addEventListener("click", hideLightbox);
  </script>
</Base>
