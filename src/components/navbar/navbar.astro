---
import Container from "../container.astro";
import Link from "../ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems } from "astro-navbar";

const menuitems = [
  {
    title: "Scolaires & professionnels",
    path: "#",
    children: [
      { title: "Un atelier pour chaque public", path: "/atelier-de-groupe" },
      { title: "Écoles primaires", path: "/ecoles-primaires" },
      { title: "Collèges", path: "/colleges" },
      { title: "Lycées", path: "/formats-atelier-pour-les-lycees" },
      { title: "Universités et grandes écoles", path: "/universites-et-grandes-ecoles" },
      { title: "Comités d’entreprise", path: "/comites-entreprise" },
      { title: "Maisons de retraite", path: "/maisons-de-retraite" },
    ],
  },
  { title: "Cours individuels à domicile", path: "/cours-individuel-a-domicile" },
  { title: "Cours de chinois", path: "/cours-de-chinois" },
  { title: "Galerie", path: "/galerie" },
  {
    title: "Traductions",
    path: "#",
    children: [
      {
        title: "LU YIN",
         path: "/etude-de-vie-de-lu-yin-de-oeuvre" },
          { title: "Les influences littéraires étrangères…", path: "/influences-litteraires-etrangeres-loeuvre-de-lu-yin" },
          { title: "Lu Yin dans le monde littéraire chinois…", path: "/lu-yin-monde-litteraire-chinois-annees-1920-1930" },
 	  { title: "Père (nouvelle)", path: "/pere-nouvelle" },
              { title: "Le 19 septembre", path: "/le-19-septembre" },
              { title: "Le 20 septembre", path: "/le-20-septembre" },
              { title: "Le 22 septembre", path: "/le-22-septembre" },
              { title: "Le 28 septembre", path: "/le-28-septembre" },
              { title: "Le 5 octobre", path: "/le-5-octobre" },
              { title: "Le 6 octobre", path: "/le-6-octobre" },
      {
        title: "ZENG JIXIN",
         path: "/zeng-jixin" },
          { title: "La guerre entre les rats et les hommes", path: "/zeng-jixin-la-guerre-entre-les-rats-et-les-hommes-nouvelle" },
          { title: "L’instinct animal", path: "/instinct-animal" },
          { title: "Mes premiers souvenirs", path: "/217-2" },
          { title: "Un repaire pour les rats et les serpents", path: "/un-repaire-pour-les-rats-et-les-serpents" },
          { title: "L’engeance de rat se déchaîne", path: "/lengeance-de-rat-se-dechaine" },
          { title: "Les mânes des morts", path: "/les-manes-des-morts" },
    ],
  },
  {
    title: "Qui sommes-nous",
    path: "#",
    children: [
      { title: "Le calligraphe", path: "/le-calligraphe" },
      { title: "La voie du pinceau", path: "/shodo-voie-pinceau" },
      { title: "Calligraphie zen", path: "/calligraphie-zen" },
    ],
  },
];
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5 border-b border-gray-100 dark:border-gray-700 pb-4">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg">
          <span class="font-bold text-gray-800 dark:text-gray-100">Calligraphie </span>
          <span class="text-gray-500 dark:text-gray-400">chinoise Lyon</span>
        </a>
        <div class="block lg:hidden">
          <button
            class="astronav-toggle p-2 rounded text-gray-800 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition"
            aria-label="Ouvrir le menu"
            aria-expanded="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex lg:px-3 py-2 items-center text-gray-700 hover:text-gray-900 dark:text-gray-300 dark:hover:text-gray-100">
                      <span>{item.title}</span>
                      {item.badge && (
                        <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-white bg-gray-600 rounded-full">
                          New
                        </span>
                      )}
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>
        <div class="lg:ml-4 mt-3 lg:mt-0 flex items-center gap-2">
          <a
            href="mailto:christophe.desmur@orange.fr"
            class="px-4 py-2 rounded bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 dark:bg-gray-200 dark:text-gray-900 dark:hover:bg-gray-300 transition whitespace-nowrap">
            Contactez-nous
          </a>
          <button
            id="theme-toggle"
            aria-label="Basculer le mode sombre/clair"
            class="p-2 rounded-lg text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition">
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </MenuItems>
    </Astronav>
  </header>
</Container>
