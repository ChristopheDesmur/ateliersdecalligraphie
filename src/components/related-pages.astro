---
export interface Props {
  current: string;
}
const { current } = Astro.props;

const allPages = [
  { href: "/atelier-de-groupe", label: "Un atelier pour chaque public" },
  { href: "/ecoles-primaires", label: "Écoles primaires" },
  { href: "/colleges", label: "Collèges" },
  { href: "/formats-atelier-pour-les-lycees", label: "Lycées" },
  { href: "/universites-et-grandes-ecoles", label: "Universités et grandes écoles" },
  { href: "/comites-entreprise", label: "Comités d'entreprise" },
  { href: "/maisons-de-retraite", label: "Maisons de retraite" },
  { href: "/cours-individuel-a-domicile", label: "Cours individuels à domicile" },
];

const links = allPages.filter(p => p.href !== current);
---

<nav class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-600">
  <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-4">Voir aussi</p>
  <ul class="flex flex-wrap gap-3">
    <li>
      <a href="/" class="inline-block px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition">
        Accueil
      </a>
    </li>
    {links.map(link => (
      <li>
        <a href={link.href} class="inline-block px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition">
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
