---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import InfoBox from "@/components/info-box.astro";

import "../styles/global.css";
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const metaDescription = description ?? "Cours de calligraphie chinoise à Lyon avec Christophe Desmur. Ateliers collectifs, cours particuliers et interventions en écoles, associations et entreprises.";

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.webp", Astro.site).toString();

const makeTitle = title ? `${title} | Calligraphie chinoise Lyon` : "Calligraphie chinoise Lyon – Christophe Desmur";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Calligraphie chinoise Lyon`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Calligraphie chinoise Lyon",
        },
      }}
    />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Calligraphie chinoise Lyon",
      "description": "Cours de calligraphie chinoise à Lyon : ateliers collectifs, cours particuliers et interventions en écoles, associations et entreprises.",
      "url": "https://ateliersdecalligraphie.com",
      "telephone": ["+33472078861", "+33769941643"],
      "email": "christophe.desmur@orange.fr",
      "image": "https://ateliersdecalligraphie.com/opengraph.webp",
      "priceRange": "€€",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "11, rue Dumenge",
        "addressLocality": "Lyon",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 45.776853,
        "longitude": 4.831559
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Monday",
          "opens": "18:30",
          "closes": "20:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Wednesday",
          "opens": "10:00",
          "closes": "12:00"
        }
      ],
      "location": [
        {
          "@type": "Place",
          "name": "Dojo zen de Lyon",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "11, rue Dumenge",
            "addressLocality": "Lyon",
            "addressCountry": "FR"
          }
        },
        {
          "@type": "Place",
          "name": "Boutique Miroirs du Ciel",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "9, rue de Belfort",
            "addressLocality": "Lyon",
            "addressCountry": "FR"
          }
        }
      ]
    })} />
    <slot name="head" />
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-800 dark:text-gray-200">
    <Navbar />

    <main class="mx-auto max-w-[1300px] flex flex-col lg:flex-row gap-8 px-4 py-8">
      <div class="flex-1">
        <slot /> <!-- Page content -->
      </div>

      <aside class="lg:w-1/3">
        <InfoBox /> <!-- Info box appears on all pages -->
      </aside>
    </main>

    <Footer />

    <style is:global>
      /* Improve page speed */
      img {
        content-visibility: auto;
      }
    </style>

    <script>
      function syncIcon() {
        const isDark = document.documentElement.classList.contains('dark');
        const sun = document.getElementById('icon-sun');
        const moon = document.getElementById('icon-moon');
        if (sun) sun.classList.toggle('hidden', !isDark);
        if (moon) moon.classList.toggle('hidden', isDark);
      }

      syncIcon();

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcon();
      });
    </script>
  </body>
</html>
