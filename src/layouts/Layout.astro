---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import InfoBox from "@/components/info-box.astro";

import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const metaDescription = description ?? "Cours de calligraphie chinoise à Lyon avec Christophe Desmur. Ateliers collectifs, cours particuliers et interventions en écoles, associations et entreprises.";

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.webp", Astro.site).toString();

const makeTitle = title ? `${title} | Calligraphie Lyon` : "Calligraphie chinoise à Lyon – Ateliers Christophe Desmur";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.webp" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Ateliers de calligraphie chinoise à Lyon`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Ateliers de calligraphie chinoise à Lyon",
        },
      }}
    />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Ateliers de calligraphie chinoise – Christophe Desmur",
      "description": "Cours de calligraphie chinoise à Lyon : ateliers collectifs, cours particuliers et interventions en écoles, associations et entreprises.",
      "url": "https://ateliersdecalligraphie.com",
      "telephone": ["+33472078861", "+33769941643"],
      "email": "christophe.desmur@orange.fr",
      "image": "https://ateliersdecalligraphie.com/opengraph.webp",
      "priceRange": "€€",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "11, rue Dumenge",
        "addressLocality": "Lyon",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 45.776853,
        "longitude": 4.831559
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Monday",
          "opens": "18:30",
          "closes": "20:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Wednesday",
          "opens": "10:00",
          "closes": "12:00"
        }
      ],
      "location": [
        {
          "@type": "Place",
          "name": "Dojo zen de Lyon",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "11, rue Dumenge",
            "addressLocality": "Lyon",
            "addressCountry": "FR"
          }
        },
        {
          "@type": "Place",
          "name": "Boutique Miroirs du Ciel",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "9, rue de Belfort",
            "addressLocality": "Lyon",
            "addressCountry": "FR"
          }
        }
      ]
    })} />
    <slot name="head" />
  </head>
  <body class="bg-white text-gray-900">
    <Navbar />

    <main class="mx-auto max-w-[1300px] flex flex-col lg:flex-row gap-8 px-4 py-8">
      <div class="flex-1">
        <slot /> <!-- Page content -->
      </div>

      <aside class="lg:w-1/3">
        <InfoBox /> <!-- Info box appears on all pages -->
      </aside>
    </main>

    <Footer />

    <style is:global>
      /* Improve page speed */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
